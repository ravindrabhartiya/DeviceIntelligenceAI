<Page
    x:Class="DeviceIntelligenceAI.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DeviceIntelligenceAI.App.Views">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="800">
            <!-- Header -->
            <TextBlock Text="Device Intelligence" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Semantic knowledge graph for your Windows device"
                       Style="{StaticResource SubtitleTextBlockStyle}" Opacity="0.7" />

            <!-- Health Summary Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Health Summary" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="HealthSummaryText"
                               Text="Loading..."
                               TextWrapping="Wrap"
                               Opacity="0.8" />
                    <Button x:Name="RefreshHealthButton" Content="&#xE72C; Refresh from Device"
                            Click="RefreshHealth_Click" />
                </StackPanel>
            </Border>

            <!-- Ingestion Progress Card (hidden until refresh) -->
            <Border x:Name="ProgressCard"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="8" Padding="20" Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Ingestion Progress" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ProgressBar x:Name="IngestionProgress" IsIndeterminate="False" Minimum="0" Maximum="5" Value="0" />
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="Step1Icon" Glyph="&#xEA3A;" FontSize="14" Opacity="0.4" />
                            <TextBlock x:Name="Step1Text" Text="Initialize graph store" Opacity="0.4" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="Step2Icon" Glyph="&#xEA3A;" FontSize="14" Opacity="0.4" />
                            <TextBlock x:Name="Step2Text" Text="Connect to Device Intelligence MCP" Opacity="0.4" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="Step3Icon" Glyph="&#xEA3A;" FontSize="14" Opacity="0.4" />
                            <TextBlock x:Name="Step3Text" Text="Ingest device twin into knowledge graph" Opacity="0.4" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="Step4Icon" Glyph="&#xEA3A;" FontSize="14" Opacity="0.4" />
                            <TextBlock x:Name="Step4Text" Text="Build semantic index" Opacity="0.4" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="Step5Icon" Glyph="&#xEA3A;" FontSize="14" Opacity="0.4" />
                            <TextBlock x:Name="Step5Text" Text="Generate health summary" Opacity="0.4" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="IngestionStatusText" Text="" Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Graph Stats Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Knowledge Graph" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="EntityCountText" Text="0" FontSize="32" FontWeight="Bold" />
                            <TextBlock Text="Entities" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="EdgeCountText" Text="0" FontSize="32" FontWeight="Bold" />
                            <TextBlock Text="Edges" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="FactCountText" Text="0" FontSize="32" FontWeight="Bold" />
                            <TextBlock Text="Facts" Opacity="0.6" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Is it safe to update?" Click="UpdateRisk_Click" />
                        <Button Content="Why did update fail?" Click="ExplainFailure_Click" />
                        <Button Content="What changed?" Click="WhatChanged_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action Result -->
            <Border x:Name="ResultCard"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="8" Padding="20" Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ResultTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel x:Name="ResultStatusPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                        <ProgressRing x:Name="ResultProgress" IsActive="False" Width="16" Height="16" />
                        <TextBlock x:Name="ResultStatus" Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="ResultText" TextWrapping="Wrap" />
                    <TextBlock x:Name="ResultSources" Opacity="0.5" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
